<view class="container home-page">
  <view class="hero">
    <view class="hero-noise"></view>
    <view class="hero-topline">
      <view class="hero-badge">SBTI TEST ATLAS</view>
      <button class="btn-share ghost" open-type="share">分享</button>
    </view>
    <view class="hero-title">人格测试宇宙</view>
    <view class="hero-desc">人格测试、MBTI测试、DISC测试、九型人格、霍兰德职业兴趣、爱之语言、EQ情绪能力与麋鹿趣味测试合集。</view>
    <view class="hero-actions" wx:if="{{featured}}">
      <navigator class="btn-primary" url="{{featured.entryUrl}}">开始 SBTI 主测</navigator>
      <button class="btn-secondary" bindtap="onCategoryChange" data-key="market_hot">看热门模块</button>
    </view>
    <view class="framework-strip">
      <view class="framework-tag" wx:for="{{frameworkTags}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <view class="stats-grid">
    <view class="stat-card">
      <view class="stat-value">{{stats.moduleCount}}</view>
      <view class="stat-label">总模块</view>
    </view>
    <view class="stat-card hot">
      <view class="stat-value">{{stats.hotCount}}</view>
      <view class="stat-label">热门推荐</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{stats.questionCount}}</view>
      <view class="stat-label">题库题量</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{stats.totalMinutes}}</view>
      <view class="stat-label">约分钟</view>
    </view>
  </view>

  <view class="seo-card card">
    <view class="eyebrow dark">SEARCH INTENT</view>
    <view class="seo-title">小程序搜索关键词承接</view>
    <view class="seo-desc">首页显式覆盖用户常搜词，方便微信收录和用户快速判断内容范围。后台名称、简介和服务类目仍需在公众平台配置。</view>
    <view class="keyword-cloud">
      <view class="keyword-chip" wx:for="{{searchKeywords}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <view class="section-toolbar" wx:if="{{newReleaseModules.length}}">
    <view>
      <view class="eyebrow">NEW RELEASES</view>
      <view class="section-title">新上线四件套</view>
    </view>
    <view class="shelf-note">已接入</view>
  </view>

  <view class="release-grid" wx:if="{{newReleaseModules.length}}">
    <navigator class="release-card accent-{{item.accent}}" wx:for="{{newReleaseModules}}" wx:key="id" url="{{item.entryUrl}}">
      <view class="release-top">
        <view class="release-badge">{{item.badge}}</view>
        <view class="release-meta">{{item.questionCount}} 题 · {{item.estimatedMinutes}} 分钟</view>
      </view>
      <view class="release-title">{{item.title}}</view>
      <view class="release-desc">{{item.description}}</view>
      <view class="release-audience">{{item.audience}}</view>
    </navigator>
  </view>

  <view class="shelf-head">
    <view>
      <view class="eyebrow">TRENDING SHELF</view>
      <view class="section-title">热门测试货架</view>
    </view>
    <view class="shelf-note">新题库</view>
  </view>

  <scroll-view class="hot-scroll" scroll-x="true" enable-flex="true" show-scrollbar="false">
    <view class="hot-track">
      <navigator
        class="hot-card accent-{{item.accent}}"
        wx:for="{{hotModules}}"
        wx:key="id"
        url="{{item.entryUrl}}"
      >
        <view class="hot-rank">TOP {{index + 1}}</view>
        <view class="hot-title">{{item.title}}</view>
        <view class="hot-desc">{{item.description}}</view>
        <view class="hot-audience">{{item.audience}}</view>
        <view class="hot-meta">
          <text>{{item.questionCount}} 题</text>
          <text>{{item.estimatedMinutes}} 分钟</text>
        </view>
        <view class="hot-source">{{item.sourceLabel}}</view>
      </navigator>
    </view>
  </scroll-view>

  <view class="section-toolbar">
    <view>
      <view class="eyebrow">GUIDED PATH</view>
      <view class="section-title">按目标选测试</view>
    </view>
  </view>

  <view class="track-grid">
    <view class="track-card" wx:for="{{journeyTracks}}" wx:for-item="track" wx:key="key">
      <view class="track-title">{{track.title}}</view>
      <view class="track-desc">{{track.desc}}</view>
      <view class="track-modules">
        <navigator class="track-link" wx:for="{{track.modules}}" wx:for-item="module" wx:key="id" url="{{module.entryUrl}}">
          {{module.title}}
        </navigator>
      </view>
    </view>
  </view>

  <view class="source-card card">
    <view class="source-title">内容口径</view>
    <view class="source-desc">只参考公开框架维度做原创题，不搬运原量表题；结果只做趣味画像、自我观察和社交分享。</view>
    <view class="guide-item" wx:for="{{introPoints}}" wx:key="*this">
      <view class="guide-dot"></view>
      <view class="guide-text">{{item}}</view>
    </view>
  </view>

  <view class="section-toolbar">
    <view>
      <view class="eyebrow">MODULE MAP</view>
      <view class="section-title">选择测试分区</view>
    </view>
  </view>

  <scroll-view class="category-scroll" scroll-x="true" enable-flex="true" show-scrollbar="false">
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="category-chip {{activeCategory === item.key ? 'active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onCategoryChange"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view class="section-zone" wx:if="{{activeCategory === 'all'}}">
    <view class="section-card card" wx:for="{{sectionedModules}}" wx:for-item="section" wx:key="key">
      <view class="section-head">
        <view>
          <view class="section-label">{{section.label}}</view>
          <view class="section-meta">{{section.count}} 个模块 · {{section.questionCount}} 题</view>
        </view>
      </view>

      <view class="module-list">
        <view class="module-card accent-{{module.accent}}" wx:for="{{section.modules}}" wx:for-item="module" wx:key="id">
          <view class="module-head">
            <view>
              <view class="module-sub">{{module.subtitle}} · {{module.categoryLabel}}</view>
              <view class="module-title">{{module.title}}</view>
            </view>
            <view class="badge-stack">
              <view class="badge">{{module.badge}}</view>
              <view class="hot-badge" wx:if="{{module.hotRank}}">热门</view>
            </view>
          </view>
          <view class="module-desc">{{module.description}}</view>
          <view class="module-audience">{{module.audience}}</view>
          <view class="meta-row">
            <text>{{module.questionCount}} 题</text>
            <text>约 {{module.estimatedMinutes}} 分钟</text>
            <text wx:if="{{module.sourceLabel}}">{{module.sourceLabel}}</text>
          </view>
          <navigator class="btn-light" url="{{module.entryUrl}}">进入测评</navigator>
        </view>
      </view>
    </view>
  </view>

  <view class="module-list filtered" wx:else>
    <view class="module-card accent-{{item.accent}}" wx:for="{{filteredModules}}" wx:key="id">
      <view class="module-head">
        <view>
          <view class="module-sub">{{item.subtitle}} · {{item.categoryLabel}}</view>
          <view class="module-title">{{item.title}}</view>
        </view>
        <view class="badge-stack">
          <view class="badge">{{item.badge}}</view>
          <view class="hot-badge" wx:if="{{item.hotRank}}">热门</view>
        </view>
      </view>
      <view class="module-desc">{{item.description}}</view>
      <view class="module-audience">{{item.audience}}</view>
      <view class="meta-row">
        <text>{{item.questionCount}} 题</text>
        <text>约 {{item.estimatedMinutes}} 分钟</text>
        <text wx:if="{{item.sourceLabel}}">{{item.sourceLabel}}</text>
      </view>
      <navigator class="btn-light" url="{{item.entryUrl}}">进入测评</navigator>
    </view>
  </view>

  <view class="section-toolbar">
    <view>
      <view class="eyebrow">ROADMAP</view>
      <view class="section-title">后续可扩展方向</view>
    </view>
  </view>

  <view class="idea-list">
    <view class="idea-card" wx:for="{{nextTestIdeas}}" wx:key="title">
      <view class="idea-head">
        <view class="idea-title">{{item.title}}</view>
        <view class="idea-keyword">{{item.keyword}}</view>
      </view>
      <view class="idea-desc">{{item.desc}}</view>
    </view>
  </view>

  <view class="empty card" wx:if="{{activeCategory !== 'all' && !filteredModules.length}}">
    <view class="empty-title">当前分类暂无模块</view>
    <view class="empty-desc">切换上方分类查看其它测试内容。</view>
  </view>
</view>
