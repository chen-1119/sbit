.home-page {
  padding-bottom: 46rpx;
}

.hero {
  position: relative;
  overflow: hidden;
  border-radius: 40rpx;
  padding: 34rpx;
  color: #fdf8ed;
  background:
    radial-gradient(circle at 88% 12%, rgba(255, 214, 102, 0.45), transparent 28%),
    radial-gradient(circle at 8% 86%, rgba(76, 181, 164, 0.38), transparent 34%),
    linear-gradient(136deg, #121a22 0%, #203b3e 48%, #8d3f2a 100%);
  box-shadow: 0 28rpx 70rpx rgba(18, 26, 34, 0.24);
  margin-bottom: 18rpx;
}

.hero-noise {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  opacity: 0.16;
  background-image:
    linear-gradient(90deg, rgba(255,255,255,0.14) 1rpx, transparent 1rpx),
    linear-gradient(0deg, rgba(255,255,255,0.12) 1rpx, transparent 1rpx);
  background-size: 36rpx 36rpx;
  pointer-events: none;
}

.hero-topline,
.hero-actions,
.shelf-head,
.section-toolbar,
.section-head,
.module-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-badge,
.eyebrow {
  position: relative;
  display: inline-block;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: #ffd666;
  font-weight: 700;
}

.hero-title {
  position: relative;
  margin-top: 34rpx;
  font-family: 'Songti SC', 'STSong', serif;
  font-size: 72rpx;
  line-height: 0.98;
  font-weight: 900;
  color: #fff8e8;
}

.hero-desc {
  position: relative;
  margin-top: 20rpx;
  max-width: 620rpx;
  font-size: 26rpx;
  line-height: 1.72;
  color: rgba(255, 248, 232, 0.86);
}

.hero-actions {
  position: relative;
  margin-top: 26rpx;
}

.btn-primary,
.btn-secondary,
.btn-share,
.btn-light {
  border: none;
  border-radius: 999rpx;
  font-size: 25rpx;
}

.btn-primary {
  flex: 1;
  height: 82rpx;
  line-height: 82rpx;
  color: #152128;
  background: linear-gradient(135deg, #ffd666, #f7a35c);
  font-weight: 700;
}

.btn-secondary {
  width: 220rpx;
  height: 82rpx;
  line-height: 82rpx;
  color: #fff8e8;
  background: rgba(255, 255, 255, 0.16);
  border: 2rpx solid rgba(255, 255, 255, 0.22);
}

.btn-share.ghost {
  width: 118rpx;
  height: 58rpx;
  line-height: 58rpx;
  color: #fff8e8;
  background: rgba(255, 255, 255, 0.14);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.framework-strip {
  position: relative;
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.framework-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  color: rgba(255, 248, 232, 0.88);
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

.stats-grid {
  display: flex;
  gap: 10rpx;
  margin-bottom: 22rpx;
}

.stat-card {
  flex: 1;
  padding: 18rpx 8rpx;
  text-align: center;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.88);
  border: 2rpx solid rgba(217, 210, 199, 0.64);
  box-shadow: 0 12rpx 32rpx rgba(28, 35, 52, 0.06);
}

.stat-card.hot {
  background: #1f6f78;
}

.stat-card.hot .stat-value,
.stat-card.hot .stat-label {
  color: #fff8e8;
}

.stat-value {
  color: #1f6f78;
  font-size: 36rpx;
  font-weight: 850;
}

.stat-label {
  margin-top: 6rpx;
  color: #68727e;
  font-size: 20rpx;
}

.shelf-head,
.section-toolbar {
  margin: 22rpx 2rpx 14rpx;
}

.section-title {
  margin-top: 4rpx;
  font-size: 34rpx;
  font-weight: 820;
  color: #1d2730;
  font-family: 'Songti SC', 'STSong', serif;
}

.shelf-note {
  padding: 8rpx 16rpx;
  color: #8d3f2a;
  background: rgba(232, 122, 93, 0.14);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.hot-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.hot-track {
  display: inline-flex;
  gap: 14rpx;
  padding: 2rpx 4rpx 10rpx;
}

.hot-card {
  width: 430rpx;
  min-height: 300rpx;
  box-sizing: border-box;
  display: inline-flex;
  flex-direction: column;
  justify-content: space-between;
  white-space: normal;
  padding: 24rpx;
  border-radius: 30rpx;
  color: #24303d;
  background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,250,240,0.92));
  border: 2rpx solid rgba(217, 210, 199, 0.7);
  box-shadow: 0 16rpx 40rpx rgba(28, 35, 52, 0.08);
}

.hot-rank {
  font-size: 20rpx;
  color: #a1442b;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.hot-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  line-height: 1.22;
  color: #18242d;
  font-weight: 820;
}

.hot-desc {
  margin-top: 12rpx;
  font-size: 23rpx;
  color: #5d6976;
  line-height: 1.56;
}

.hot-meta,
.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  color: #78808a;
  font-size: 22rpx;
}

.hot-source {
  margin-top: 14rpx;
  display: inline-block;
  color: #1f6f78;
  font-size: 21rpx;
  font-weight: 700;
}

.source-card {
  padding: 26rpx;
  margin-bottom: 22rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 214, 102, 0.18), transparent 36%),
    #fffdf8;
}

.source-title {
  font-size: 30rpx;
  color: #1d2730;
  font-weight: 800;
}

.source-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5d6976;
  line-height: 1.65;
}

.guide-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 12rpx;
}

.guide-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #e87a5d;
  flex-shrink: 0;
}

.guide-text {
  font-size: 23rpx;
  color: #5f6974;
  line-height: 1.62;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.category-list {
  display: inline-flex;
  gap: 10rpx;
  padding: 2rpx 4rpx 8rpx;
}

.category-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #51616f;
  background: rgba(90, 98, 107, 0.11);
  border: 2rpx solid transparent;
}

.category-chip.active {
  color: #fff8e8;
  background: #1f6f78;
  border-color: rgba(31, 111, 120, 0.3);
}

.section-zone,
.module-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-card {
  padding: 20rpx;
  background: rgba(255, 253, 248, 0.94);
}

.section-head {
  align-items: flex-start;
  margin-bottom: 14rpx;
  padding: 4rpx;
}

.section-label {
  font-size: 29rpx;
  color: #1d2730;
  font-weight: 820;
}

.section-meta {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #78808a;
}

.module-card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: #fffaf0;
  border: 2rpx solid rgba(217, 210, 199, 0.68);
  box-shadow: 0 10rpx 28rpx rgba(28, 35, 52, 0.06);
}

.module-sub {
  font-size: 22rpx;
  color: #6b7480;
  margin-bottom: 6rpx;
}

.module-title {
  font-size: 34rpx;
  font-weight: 820;
  color: #23303d;
  line-height: 1.3;
}

.badge-stack {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
  flex-shrink: 0;
}

.badge,
.hot-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  white-space: nowrap;
}

.badge {
  color: #1f6f78;
  background: rgba(31, 111, 120, 0.12);
}

.hot-badge {
  color: #8d3f2a;
  background: rgba(255, 214, 102, 0.32);
}

.module-desc {
  margin-top: 14rpx;
  color: #596470;
  font-size: 24rpx;
  line-height: 1.65;
}

.meta-row {
  margin-top: 14rpx;
}

.btn-light {
  margin-top: 16rpx;
  width: 100%;
  height: 78rpx;
  line-height: 78rpx;
  color: #fff8e8;
  background: #22313a;
}

.accent-teal,
.accent-green {
  border-left: 10rpx solid #1f6f78;
}

.accent-orange,
.accent-red {
  border-left: 10rpx solid #e87a5d;
}

.accent-blue {
  border-left: 10rpx solid #3f6ec7;
}

.accent-purple {
  border-left: 10rpx solid #8265c7;
}

.accent-pink {
  border-left: 10rpx solid #d96a8c;
}

.empty {
  padding: 28rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #2f3b48;
  font-weight: 700;
}

.empty-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #64707d;
}
