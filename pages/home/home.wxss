.home-page {
  padding-bottom: 42rpx;
}

.hero {
  border-radius: 34rpx;
  padding: 34rpx;
  background:
    radial-gradient(circle at 86% 14%, rgba(232, 122, 93, 0.22), transparent 36%),
    linear-gradient(150deg, rgba(255, 255, 255, 0.96), rgba(255, 248, 242, 0.92));
  border: 2rpx solid rgba(216, 95, 63, 0.2);
  box-shadow: 0 18rpx 46rpx rgba(232, 122, 93, 0.12);
  margin-bottom: 18rpx;
}

.hero-badge {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  color: #165c63;
  background: rgba(31, 111, 120, 0.12);
}

.hero-title {
  margin-top: 16rpx;
  font-size: 58rpx;
  font-weight: 700;
  color: #1e262f;
}

.hero-desc {
  margin-top: 14rpx;
  font-size: 25rpx;
  color: #5f6771;
  line-height: 1.7;
}

.tag-list {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  color: #50606b;
  border-radius: 999rpx;
  background: rgba(90, 98, 107, 0.12);
}

.card {
  background: #fffdf8;
  border-radius: 26rpx;
  border: 2rpx solid rgba(217, 210, 199, 0.7);
  padding: 26rpx;
}

.overview {
  margin-bottom: 18rpx;
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
}

.overview-item {
  flex: 1;
  text-align: center;
  border-radius: 16rpx;
  background: rgba(31, 111, 120, 0.06);
  padding: 14rpx 8rpx;
}

.overview-value {
  color: #1f6f78;
  font-size: 36rpx;
  font-weight: 700;
}

.overview-label {
  margin-top: 6rpx;
  color: #5a6672;
  font-size: 21rpx;
}

.featured {
  margin-bottom: 18rpx;
}

.accent-teal {
  border-left: 10rpx solid #1f6f78;
}

.accent-orange {
  border-left: 10rpx solid #e87a5d;
}

.accent-blue {
  border-left: 10rpx solid #3f6ec7;
}

.accent-green {
  border-left: 10rpx solid #3f8c57;
}

.accent-purple {
  border-left: 10rpx solid #8265c7;
}

.module-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.module-card {
  margin-bottom: 4rpx;
}

.section-zone {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.section-card {
  padding: 20rpx;
  background: rgba(255, 253, 248, 0.92);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 6rpx 4rpx;
}

.section-label {
  font-size: 28rpx;
  color: #2a3644;
  font-weight: 700;
}

.section-meta {
  display: flex;
  gap: 12rpx;
  font-size: 21rpx;
  color: #6b7682;
}

.module-head,
.featured-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.badge-stack {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.module-sub {
  font-size: 22rpx;
  color: #6b7480;
  margin-bottom: 6rpx;
}

.module-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #23303d;
  line-height: 1.3;
}

.badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  color: #1f6f78;
  background: rgba(31, 111, 120, 0.12);
}

.adult-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  color: #a1442b;
  background: rgba(232, 122, 93, 0.16);
}

.module-desc {
  margin-top: 14rpx;
  color: #596470;
  font-size: 24rpx;
  line-height: 1.65;
}

.meta-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  color: #78808a;
  font-size: 22rpx;
}

.btn-enter,
.btn-light {
  margin-top: 16rpx;
  border: none;
  border-radius: 999rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 26rpx;
}

.btn-enter {
  color: #fff;
  background: linear-gradient(130deg, #1f6f78 0%, #2d7f88 58%, #e87a5d 100%);
}

.btn-light {
  color: #3f4a56;
  background: rgba(90, 98, 107, 0.13);
}

.section-title {
  margin: 16rpx 0 14rpx;
  padding-left: 4rpx;
  font-size: 28rpx;
  font-weight: 650;
  color: #2f3b48;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 14rpx;
}

.category-list {
  display: inline-flex;
  gap: 10rpx;
  padding: 2rpx 4rpx;
}

.category-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  color: #51616f;
  background: rgba(90, 98, 107, 0.12);
  border: 2rpx solid transparent;
}

.category-chip.active {
  color: #1f6f78;
  background: rgba(31, 111, 120, 0.14);
  border-color: rgba(31, 111, 120, 0.3);
}

.empty-title {
  font-size: 28rpx;
  color: #2f3b48;
  font-weight: 650;
}

.empty-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #64707d;
}

.guide-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.guide-item:last-child {
  margin-bottom: 0;
}

.guide-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #e87a5d;
  flex-shrink: 0;
}

.guide-text {
  font-size: 24rpx;
  color: #5e6873;
  line-height: 1.65;
}
