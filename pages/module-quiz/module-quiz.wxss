.module-quiz {
  padding-bottom: 28rpx;
}

.head {
  margin-bottom: 18rpx;
}

.module-sub {
  font-size: 22rpx;
  color: #6d7782;
}

.module-title {
  margin-top: 6rpx;
  font-size: 38rpx;
  color: #24303d;
  font-weight: 700;
}

.module-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #5a6672;
  line-height: 1.62;
}

.progress-container {
  margin-bottom: 18rpx;
}

.progress-text {
  display: flex;
  justify-content: space-between;
  color: #5f6770;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.progress-bar {
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(31, 111, 120, 0.14);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1f6f78, #e87a5d);
  transition: width 0.28s ease;
}

.eta {
  margin-top: 8rpx;
  color: #7a828d;
  font-size: 22rpx;
}

.question-text {
  font-size: 34rpx;
  color: #29333f;
  font-weight: 650;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.option {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(217, 210, 199, 0.75);
  background: #fffdf9;
}

.option.active {
  border-color: rgba(31, 111, 120, 0.6);
  background: rgba(31, 111, 120, 0.08);
}

.option-letter {
  width: 50rpx;
  height: 50rpx;
  border-radius: 12rpx;
  background: rgba(232, 122, 93, 0.14);
  color: #a1442b;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option.active .option-letter {
  color: #fff;
  background: #1f6f78;
}

.option-text {
  font-size: 27rpx;
  line-height: 1.6;
  color: #42505d;
}

.nav-buttons {
  display: flex;
  gap: 12rpx;
}

.btn-prev,
.btn-next {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 27rpx;
  border: none;
}

.btn-prev {
  color: #46525f;
  background: rgba(90, 98, 107, 0.13);
}

.btn-next {
  color: #fff;
  background: linear-gradient(130deg, #1f6f78, #e87a5d);
}

.btn-next.disabled {
  background: #bcc2c9;
}

.warning {
  margin-top: 12rpx;
  text-align: center;
  color: #c03f22;
  font-size: 23rpx;
  opacity: 0;
  transition: opacity 0.2s;
}

.warning.show {
  opacity: 1;
}
