.module-quiz {
  padding-bottom: 34rpx;
}

.quiz-hero {
  position: relative;
  overflow: hidden;
  margin-bottom: 18rpx;
  padding: 30rpx;
  border-radius: 34rpx;
  color: #fdf8ed;
  background:
    radial-gradient(circle at 88% 14%, rgba(255, 214, 102, 0.34), transparent 32%),
    linear-gradient(138deg, #162229, #24494b 58%, #8d3f2a);
  box-shadow: 0 22rpx 56rpx rgba(18, 26, 34, 0.18);
}

.quiz-topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.module-sub {
  font-size: 22rpx;
  color: rgba(255, 248, 232, 0.72);
  letter-spacing: 2rpx;
}

.mini-share {
  width: 112rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.22);
  color: #fff8e8;
  background: rgba(255, 255, 255, 0.13);
  font-size: 22rpx;
}

.module-title {
  margin-top: 18rpx;
  font-family: 'Songti SC', 'STSong', serif;
  font-size: 48rpx;
  color: #fff8e8;
  font-weight: 900;
  line-height: 1.14;
}

.module-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 248, 232, 0.82);
  line-height: 1.64;
}

.age-note {
  margin-top: 12rpx;
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 214, 102, 0.18);
  color: #ffe9a6;
  font-size: 22rpx;
}

.quiz-meta-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.quiz-meta-row text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: rgba(255, 248, 232, 0.86);
  background: rgba(255, 255, 255, 0.12);
  font-size: 21rpx;
}

.progress-card {
  margin-bottom: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.9);
  border: 2rpx solid rgba(217, 210, 199, 0.65);
}

.progress-text {
  display: flex;
  justify-content: space-between;
  color: #5f6770;
  font-size: 23rpx;
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(31, 111, 120, 0.12);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ffd666, #e87a5d 45%, #1f6f78);
  transition: width 0.28s ease;
}

.question-card {
  padding: 30rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 214, 102, 0.14), transparent 34%),
    #fffdf8;
}

.question-index {
  font-size: 20rpx;
  color: #a1442b;
  font-weight: 800;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.question-text {
  font-size: 36rpx;
  color: #1f2a33;
  font-weight: 820;
  line-height: 1.45;
  margin-bottom: 24rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.option {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(217, 210, 199, 0.78);
  background: #fffaf0;
  box-shadow: 0 8rpx 20rpx rgba(28, 35, 52, 0.04);
}

.option.active {
  border-color: rgba(31, 111, 120, 0.72);
  background:
    linear-gradient(135deg, rgba(31, 111, 120, 0.12), rgba(255, 214, 102, 0.18));
}

.option-letter {
  width: 54rpx;
  height: 54rpx;
  border-radius: 16rpx;
  background: #22313a;
  color: #fff8e8;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option.active .option-letter {
  color: #18242d;
  background: #ffd666;
}

.option-text {
  font-size: 27rpx;
  line-height: 1.58;
  color: #3f4d59;
}

.nav-buttons {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
}

.btn-prev,
.btn-next {
  flex: 1;
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 999rpx;
  font-size: 27rpx;
  border: none;
}

.btn-prev {
  color: #46525f;
  background: rgba(90, 98, 107, 0.13);
}

.btn-next {
  color: #fff8e8;
  background: linear-gradient(130deg, #1f6f78, #22313a);
}

.btn-next.disabled {
  background: #bcc2c9;
}

.warning {
  margin-top: 12rpx;
  text-align: center;
  color: #c03f22;
  font-size: 23rpx;
  opacity: 0;
  transition: opacity 0.2s;
}

.warning.show {
  opacity: 1;
}
