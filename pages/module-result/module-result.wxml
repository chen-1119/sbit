<view class="container module-result" wx:if="{{module}}">
  <view class="card result-head">
    <view class="module-title">{{module.title}}</view>
    <view class="profile-title">{{profile.title}}</view>
    <view class="confidence">判定清晰度：{{confidence}}</view>
    <view class="profile-desc">{{profile.desc}}</view>
    <view class="adult-note" wx:if="{{module.adultOnly}}">自我观察内容 · 不用于医学或临床诊断</view>
    <view class="submitted-time" wx:if="{{submittedAtText}}">完成时间：{{submittedAtText}}</view>
  </view>

  <view class="analysis-grid">
    <view class="analysis-card" wx:for="{{analysisCards}}" wx:key="label">
      <view class="analysis-label">{{item.label}}</view>
      <view class="analysis-value">{{item.value}}</view>
      <view class="analysis-detail">{{item.detail}}</view>
    </view>
  </view>

  <view class="card insight-card">
    <view class="section-title">结果怎么理解</view>
    <view class="insight-text">{{insightText}}</view>
    <view class="confidence-text">{{confidenceText}}</view>
  </view>

  <view class="card" wx:if="{{hasPressureIndex}}">
    <view class="section-title">表达压力概览</view>
    <view class="pressure-row">
      <view class="pressure-index">{{pressureIndex}}</view>
      <view class="pressure-info">
        <view class="pressure-level">压力水平：{{pressureLevel}}</view>
        <view class="pressure-hint">{{pressureHint}}</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">维度分布</view>
    <view class="dim-list">
      <view class="dim-item" wx:for="{{rows}}" wx:key="key">
        <view class="dim-head">
          <text class="dim-label">{{item.label}}</text>
          <text class="dim-score">{{item.percent}}%</text>
        </view>
        <view class="dim-track">
          <view class="dim-fill" style="width: {{item.percent}}%;"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">行动建议</view>
    <view class="tips">
      <view class="tip-item" wx:for="{{profile.tips}}" wx:key="*this">{{index + 1}}. {{item}}</view>
    </view>
  </view>

  <view class="card" wx:if="{{profile.cityVibe.length}}">
    <view class="section-title">适配城市气质</view>
    <view class="vibe-list">
      <text class="vibe-tag" wx:for="{{profile.cityVibe}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="card" wx:if="{{nextModules.length}}">
    <view class="section-title">下一步推荐测试</view>
    <view class="next-list">
      <navigator class="next-card" wx:for="{{nextModules}}" wx:key="id" url="{{item.entryUrl}}">
        <view>
          <view class="next-title">{{item.title}}</view>
          <view class="next-meta">{{item.reason}} · {{item.questionCount}} 题 · 约 {{item.estimatedMinutes}} 分钟</view>
        </view>
        <view class="next-badge">{{item.badge}}</view>
      </navigator>
    </view>
  </view>

  <view class="card">
    <view class="section-title">结果摘要</view>
    <view class="summary">{{summary}}</view>
    <button class="btn-copy" bindtap="copySummary">复制结果文案</button>
  </view>

  <view class="actions">
    <button class="btn-main" bindtap="retake">再测一次</button>
    <button class="btn-light" open-type="share">分享给朋友</button>
    <button class="btn-light" bindtap="goHome">返回测试中心</button>
  </view>
</view>
