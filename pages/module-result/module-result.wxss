.module-result {
  padding-bottom: 30rpx;
}

.result-head {
  margin-bottom: 16rpx;
}

.module-title {
  font-size: 30rpx;
  color: #64707d;
}

.profile-title {
  margin-top: 6rpx;
  font-size: 46rpx;
  color: #1f6f78;
  font-weight: 750;
}

.confidence {
  margin-top: 8rpx;
  display: inline-block;
  font-size: 22rpx;
  color: #a1442b;
  background: rgba(232, 122, 93, 0.14);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.profile-desc {
  margin-top: 12rpx;
  font-size: 25rpx;
  color: #4f5c69;
  line-height: 1.68;
}

.adult-note {
  margin-top: 10rpx;
  display: inline-block;
  font-size: 22rpx;
  color: #a1442b;
  background: rgba(232, 122, 93, 0.16);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.submitted-time {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7a838f;
}

.analysis-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.analysis-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(34, 49, 58, 0.96), rgba(31, 111, 120, 0.92));
  color: #fff8e8;
  box-shadow: 0 12rpx 30rpx rgba(18, 26, 34, 0.1);
}

.analysis-label {
  font-size: 20rpx;
  color: rgba(255, 248, 232, 0.66);
  letter-spacing: 2rpx;
}

.analysis-value {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 820;
}

.analysis-detail {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: rgba(255, 248, 232, 0.8);
  line-height: 1.56;
}

.section-title {
  font-size: 28rpx;
  color: #2c3845;
  font-weight: 650;
  margin-bottom: 12rpx;
}

.insight-card {
  margin-bottom: 16rpx;
  padding: 26rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 214, 102, 0.17), transparent 36%),
    #fffdf8;
}

.insight-text {
  font-size: 25rpx;
  color: #3f4d59;
  line-height: 1.68;
}

.confidence-text {
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  color: #2f5d63;
  background: rgba(31, 111, 120, 0.1);
  font-size: 23rpx;
  line-height: 1.56;
}

.pressure-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.pressure-index {
  width: 126rpx;
  height: 126rpx;
  border-radius: 50%;
  background: linear-gradient(140deg, rgba(232, 122, 93, 0.2), rgba(31, 111, 120, 0.22));
  color: #23303d;
  font-size: 46rpx;
  font-weight: 780;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pressure-info {
  flex: 1;
}

.pressure-level {
  font-size: 26rpx;
  color: #2f3b48;
  font-weight: 650;
}

.pressure-hint {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #5d6976;
  line-height: 1.64;
}

.dim-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dim-item {
  padding: 12rpx 0;
}

.dim-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.dim-label {
  font-size: 24rpx;
  color: #46525f;
}

.dim-score {
  font-size: 24rpx;
  color: #1f6f78;
  font-weight: 700;
}

.dim-track {
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(31, 111, 120, 0.14);
  overflow: hidden;
}

.dim-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1f6f78, #e87a5d);
}

.tips {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #56616e;
  line-height: 1.62;
}

.vibe-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.vibe-tag {
  font-size: 22rpx;
  color: #2f5d63;
  background: rgba(31, 111, 120, 0.13);
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
}

.next-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.next-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #fffaf0;
  border: 2rpx solid rgba(217, 210, 199, 0.72);
}

.next-title {
  font-size: 26rpx;
  color: #23303d;
  font-weight: 760;
}

.next-meta {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #73808d;
}

.next-badge {
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  color: #1f6f78;
  background: rgba(31, 111, 120, 0.12);
  font-size: 21rpx;
}

.summary {
  font-size: 24rpx;
  color: #596572;
  line-height: 1.65;
}

.btn-copy {
  margin-top: 14rpx;
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 25rpx;
  color: #3f4a57;
  background: rgba(90, 98, 107, 0.13);
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.btn-main,
.btn-light {
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 27rpx;
}

.btn-main {
  color: #fff;
  background: linear-gradient(130deg, #1f6f78, #e87a5d);
}

.btn-light {
  color: #3d4a58;
  background: rgba(90, 98, 107, 0.13);
}
